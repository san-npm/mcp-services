# Production baseline (hardened)
NODE_ENV=production

# ─── Server ───
PORT=3100
CHROMIUM_PATH=/usr/bin/chromium-browser
MAX_BROWSERS=3
MAX_SSE_SESSIONS=50
MAX_SSE_PER_IP=5
SSE_CONNECT_MAX_PER_WINDOW=30
SSE_CONNECT_WINDOW_MS=60000

# REQUIRED: set strict values for your deployment
# Examples:
# TRUST_PROXY=1                    # one reverse proxy in front
# TRUST_PROXY=loopback             # local reverse proxy only
# TRUST_PROXY=10.0.0.0/8,127.0.0.1/8
TRUST_PROXY=1
SSE_ALLOWED_HOSTS=mcp.skills.ws
SSE_ALLOWED_ORIGINS=https://mcp.skills.ws

# ─── Auth ───
FREE_DAILY_LIMIT=10
FREE_WINDOW_MS=86400000
ALLOW_APIKEY_QUERY=false
REDIS_URL=redis://127.0.0.1:6379/0
API_KEYS=
ADMIN_SECRET=REPLACE_ME_LONG_RANDOM
KEYS_FILE=./data/api-keys.json

# ─── Stripe Billing ───
STRIPE_SK=
STRIPE_WEBHOOK_SECRET=
# Optional but recommended if ingress has stable source IPs
STRIPE_WEBHOOK_IP_ALLOWLIST=
CHECKOUT_LIMIT_PER_HOUR=5
DOMAIN=https://mcp.skills.ws

# ─── x402 ───
X402_PRICE_USD=0.005
X402_RECEIVER=0x087ae921CE8d07a4dE6BdacAceD475e9080B2aDF
X402_MAX_TX_AGE_SECONDS=86400
X402_TX_CACHE_FILE=./data/x402-tx-cache.json
X402_TEST_MODE=0

# ─── Memory / optional security APIs ───
MEMORY_DB_PATH=./data/memory.db
VT_API_KEY=
ABUSEIPDB_API_KEY=
ETHERSCAN_API_KEY=
